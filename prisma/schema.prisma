generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  FEMALE
  MALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum Goal {
  FAT_LOSS
  MUSCLE_GAIN
  STRENGTH
  ENDURANCE
  WELLNESS
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  ATHLETE
}

enum WorkoutExperience {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum DietPreference {
  BALANCED
  HIGH_PROTEIN
  VEGETARIAN
  VEGAN
  MEDITERRANEAN
  LOW_CARB
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  role            Role            @default(USER)
  locale          String          @default("en")
  onboardingDone  Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        Account[]
  sessions        Session[]
  profile         Profile?
  workoutPlans    WorkoutPlan[]
  nutritionPlans  NutritionPlan[]
  progressEntries ProgressEntry[]
  measurements    Measurement[]
  subscription    Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                 String            @id @default(cuid())
  userId             String            @unique
  age                Int
  gender             Gender
  heightCm           Int
  weightKg           Decimal           @db.Decimal(5, 2)
  goal               Goal
  activityLevel      ActivityLevel
  availableEquipment String[]
  workoutExperience  WorkoutExperience
  medicalLimitations String?
  dietPreference     DietPreference
  workoutDays        Int
  workoutDurationMin Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  userId      String
  title       String
  summary     String
  provider    String   @default("deterministic")
  content     Json
  active      Boolean  @default(true)
  generatedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model NutritionPlan {
  id          String   @id @default(cuid())
  userId      String
  title       String
  summary     String
  provider    String   @default("deterministic")
  calories    Int
  proteinG    Int
  carbsG      Int
  fatG        Int
  content     Json
  active      Boolean  @default(true)
  generatedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model ProgressEntry {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime @db.Date
  workoutCompleted  Boolean  @default(false)
  nutritionAdherent Boolean  @default(false)
  waterLiters       Decimal? @db.Decimal(4, 2)
  sleepHours        Decimal? @db.Decimal(4, 2)
  energyLevel       Int?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Measurement {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  weightKg  Decimal  @db.Decimal(5, 2)
  waistCm   Decimal? @db.Decimal(5, 2)
  chestCm   Decimal? @db.Decimal(5, 2)
  hipCm     Decimal? @db.Decimal(5, 2)
  armCm     Decimal? @db.Decimal(5, 2)
  thighCm   Decimal? @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  status             SubscriptionStatus @default(FREE)
  tier               String             @default("starter")
  provider           String             @default("manual")
  providerCustomerId String?
  providerSubId      String?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}
